# Desktop-only activation/licensing config.
# Do not copy these keys into Ionic Appflow or any iOS build environment.

# Seller billing email that receives activation requests.
SELLER_EMAIL=billing@example.com

# Offline activation verification secret used by desktop renderer builds only.
VITE_SELLER_SECRET=replace-with-strong-desktop-only-secret

# Optional: same secret for the generator script.
SELLER_SECRET=replace-with-strong-desktop-only-secret
