# Copy this file to .env and adjust values for your environment
# NOTE: iOS runtime auth/purchase/sync keys are provided via Ionic Appflow Native Config,
# not from this desktop/web .env file.
# Seller billing email that receives activation requests


# Optional: same secret for the generator script (so it auto-loads from .env)
SELLER_SECRET=

# Auth.js / Google Sign-In (server)
AUTH_SECRET=replace-with-long-random-string
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Supabase admin credentials for Vercel functions
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# iOS/Appflow public runtime config. These are copied into dist-ios/passgen-runtime.json
# during npm run build so native Swift can use the same values when Xcode build settings
# are not expanded by Appflow.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-supabase-anon-key
VITE_REVENUECAT_IOS_KEY=appl_your_public_revenuecat_ios_key
IOS_SUPABASE_URL=https://your-project.supabase.co
IOS_SUPABASE_ANON_KEY=your-public-supabase-anon-key
IOS_REVENUECAT_API_KEY=appl_your_public_revenuecat_ios_key
IOS_REVENUECAT_PRO_PRODUCT_ID=passgen_pro_monthly
IOS_REVENUECAT_CLOUD_PRODUCT_ID=passgen_cloud_monthly
IOS_REVENUECAT_PRO_PACKAGE_ID=monthly
IOS_REVENUECAT_CLOUD_PACKAGE_ID=$rc_monthly



# Google Drive OAuth for Electron main (if separate project)
PASSGEN_GOOGLE_CLIENT_ID=your-drive-client-id
PASSGEN_GOOGLE_CLIENT_SECRET=your-drive-client-secret


