{
  "name": "passgen",
  "version": "1.0.39",
  "description": "PassGen Secrets Vault iOS mobile application",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite --mode ios",
    "build": "npm run build:ios:web",
    "build:ios:web": "cross-env NODE_OPTIONS=--max-old-space-size=4096 vite build --mode ios && node scripts/prepare-ios-web.js && npm run validate:ios-web",
    "preview": "vite preview",
    "validate:ios-web": "node scripts/validate-ios-artifact.js dist-ios",
    "validate:ios-artifact": "node scripts/validate-ios-artifact.js dist-ios ios/App/App/public",
    "postinstall": "patch-package"
  },
  "keywords": [
    "password",
    "generator",
    "ios",
    "capacitor"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@capacitor/cli": "^8.1.0",
    "@ionic/cli": "^7.2.1",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "cross-env": "^7.0.3",
    "patch-package": "^8.0.1",
    "supabase": "^2.98.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.8"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.925.0",
    "@capacitor-community/apple-sign-in": "^7.1.0",
    "@capacitor/clipboard": "^8.0.1",
    "@capacitor/core": "^8.1.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/preferences": "^8.0.1",
    "@codetrix-studio/capacitor-google-auth": "^3.4.0-rc.4",
    "@revenuecat/purchases-capacitor": "^12.2.0",
    "@supabase/supabase-js": "^2.89.0",
    "crypto-js": "^4.2.0",
    "googleapis": "^164.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
